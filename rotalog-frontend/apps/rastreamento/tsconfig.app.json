{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node"],
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "noImplicitOverride": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "files": ["src/main.tsx"],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["src/test.ts", "src/**/*.spec.ts", "jest.config.ts", "src/**/*.test.ts"]
}
